# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data files — raw CSVs are tracked; processed outputs are excluded ─────────
data/processed/
!data/processed/.gitkeep

# ── Visuals — regenerated by running the notebooks ────────────────────────────
visuals/
!visuals/.gitkeep

# ── Power BI ──────────────────────────────────────────────────────────────────
# .pbix files are binary; exclude if large or use Git LFS instead
# dashboard/*.pbix

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Environment variables (never commit secrets) ──────────────────────────────
.env
.env.local
*.env
myenv/

# ── PostgreSQL connection strings ─────────────────────────────────────────────
db_config.py
db_config.json
connection.ini

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
